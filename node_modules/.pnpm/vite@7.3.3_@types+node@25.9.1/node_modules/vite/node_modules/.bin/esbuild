#!/bin/sh
basedir=$(dirname "$(echo "$0" | sed -e 's,\\,/,g')")

case `uname` in
    *CYGWIN*|*MINGW*|*MSYS*)
        if command -v cygpath > /dev/null 2>&1; then
            basedir=`cygpath -w "$basedir"`
        fi
    ;;
esac

if [ -z "$NODE_PATH" ]; then
  export NODE_PATH="/home/dkrac/axis/node_modules/.pnpm/esbuild@0.27.7/node_modules/esbuild/node_modules:/home/dkrac/axis/node_modules/.pnpm/esbuild@0.27.7/node_modules:/home/dkrac/axis/node_modules/.pnpm/node_modules"
else
  export NODE_PATH="/home/dkrac/axis/node_modules/.pnpm/esbuild@0.27.7/node_modules/esbuild/node_modules:/home/dkrac/axis/node_modules/.pnpm/esbuild@0.27.7/node_modules:/home/dkrac/axis/node_modules/.pnpm/node_modules:$NODE_PATH"
fi
exec "$basedir/../../../esbuild/bin/esbuild"   "$@"
exit $?
